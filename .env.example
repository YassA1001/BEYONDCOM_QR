# ============================================================
# BeyondCom QR Event Platform - Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# If any required variable is missing, the app will refuse to start.
# ============================================================

# Database (MySQL via Prisma)
DATABASE_URL="mysql://root:password@localhost:3306/beyondcom"

# Session
SESSION_SECRET="change-me-to-a-long-random-string"

# App
APP_URL="http://localhost:3000"
NODE_ENV="development"
PORT=3000

# Seed super admin
ADMIN_NAME="BeyondCom Admin"
ADMIN_EMAIL="admin@beyondcom.local"
ADMIN_PASSWORD="Admin123456!"
