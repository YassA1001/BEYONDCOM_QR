<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title><%= event.name %></title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='<%= encodeURIComponent(color) %>'/><text x='50' y='68' font-size='52' font-family='Arial' font-weight='bold' fill='%23ffffff' text-anchor='middle'><%= event.name.charAt(0) %></text></svg>">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root { --primary: <%= color %>; }
    * { box-sizing: border-box; }
    body {
      margin: 0;
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
      background: linear-gradient(180deg, #0f172a 0%, #1e293b 100%);
      min-height: 100vh;
      color: #0f172a;
      -webkit-font-smoothing: antialiased;
    }
    .pub-wrap {
      max-width: 540px;
      margin: 0 auto;
      padding: 0 0 60px;
    }
    .pub-banner {
      position: relative;
      min-height: 200px;
      background-size: cover;
      background-position: center;
      background: linear-gradient(135deg, var(--primary), #0f172a);
      border-bottom-left-radius: 24px;
      border-bottom-right-radius: 24px;
      overflow: hidden;
    }
    .pub-banner::after {
      content: '';
      position: absolute; inset: 0;
      background: linear-gradient(180deg, rgba(15,23,42,0.05) 0%, rgba(15,23,42,0.5) 100%);
    }
    .pub-logo {
      position: absolute;
      bottom: -28px;
      left: 50%;
      transform: translateX(-50%);
      width: 88px; height: 88px;
      border-radius: 20px;
      background: #fff;
      box-shadow: 0 12px 30px rgba(0,0,0,0.25);
      overflow: hidden;
      display: flex; align-items: center; justify-content: center;
      z-index: 2;
      border: 4px solid #fff;
    }
    .pub-logo img { width: 100%; height: 100%; object-fit: cover; }
    .pub-logo-empty { font-size: 32px; color: var(--primary); font-weight: 700; }

    .pub-content {
      padding: 44px 24px 0;
      text-align: center;
    }
    .pub-title {
      font-size: 28px; font-weight: 800;
      margin: 0 0 6px;
      color: #fff;
    }
    .pub-meta {
      display: flex; flex-wrap: wrap; justify-content: center; gap: 12px 18px;
      color: #cbd5e1; font-size: 14px; margin-bottom: 14px;
    }
    .pub-meta span { display: inline-flex; align-items: center; gap: 6px; }
    .pub-description {
      color: #cbd5e1; font-size: 15px; line-height: 1.6;
      max-width: 460px; margin: 0 auto 24px;
    }

    .pub-card {
      background: #fff;
      border-radius: 20px;
      padding: 24px 18px;
      margin: 24px 16px 0;
      box-shadow: 0 20px 50px rgba(0,0,0,0.3);
    }

    .pub-links { display: flex; flex-direction: column; gap: 12px; }
    .pub-btn {
      display: flex; align-items: center; gap: 14px;
      width: 100%;
      padding: 16px 18px;
      border: 1px solid #e2e8f0;
      border-radius: 14px;
      background: #fff;
      color: #0f172a;
      text-decoration: none;
      font-weight: 600; font-size: 16px;
      transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease, background 0.18s;
      position: relative; overflow: hidden;
      opacity: 0; transform: translateY(12px);
      animation: pubBtnIn 0.5s forwards;
    }
    <% event.links.forEach(function(l, i){ %>
      .pub-link-<%= i %> { animation-delay: <%= i * 70 %>ms; }
    <% }); %>
    @keyframes pubBtnIn {
      to { opacity: 1; transform: translateY(0); }
    }
    .pub-btn:hover, .pub-btn:active {
      transform: translateY(-2px);
      box-shadow: 0 10px 25px rgba(2, 6, 23, 0.12);
      border-color: var(--primary);
    }
    .pub-btn-icon {
      width: 42px; height: 42px;
      flex: 0 0 42px;
      border-radius: 12px;
      background: var(--primary);
      color: #fff;
      display: flex; align-items: center; justify-content: center;
      font-size: 20px;
    }
    .pub-btn-title { flex: 1; text-align: left; }
    .pub-btn-arrow { color: #94a3b8; }

    .pub-empty {
      padding: 30px 16px;
      text-align: center;
      color: #64748b;
    }
    .pub-empty i { font-size: 38px; display: block; margin-bottom: 8px; color: #cbd5e1; }

    .pub-footer {
      text-align: center; color: #64748b; font-size: 13px;
      margin-top: 32px;
    }
    .pub-footer a { color: #cbd5e1; text-decoration: none; font-weight: 600; }

    @media (min-width: 600px){
      .pub-banner { min-height: 240px; }
      .pub-content { padding-top: 52px; }
    }
  </style>
</head>
<body>
  <div class="pub-wrap">
    <div class="pub-banner" <% if (event.banner){ %>style="background-image:url('<%= event.banner %>')"<% } %>>
      <% if (event.logo){ %>
        <div class="pub-logo"><img src="<%= event.logo %>" alt=""></div>
      <% } else { %>
        <div class="pub-logo"><span class="pub-logo-empty"><%= event.name.charAt(0) %></span></div>
      <% } %>
    </div>

    <div class="pub-content">
      <h1 class="pub-title"><%= event.name %></h1>
      <div class="pub-meta">
        <% if (event.city){ %><span><i class="bi bi-geo-alt-fill"></i><%= event.city %></span><% } %>
        <% if (event.location){ %><span><i class="bi bi-pin-map-fill"></i><%= event.location %></span><% } %>
        <% if (event.startDate){ %><span><i class="bi bi-calendar3"></i><%= formatDate.formatRange(event.startDate, event.endDate) %></span><% } %>
      </div>
      <% if (event.description){ %>
        <p class="pub-description"><%= event.description %></p>
      <% } %>
    </div>

    <div class="pub-card">
      <% if (event.links.length === 0){ %>
        <div class="pub-empty">
          <i class="bi bi-link-45deg"></i>
          <p>Aucun lien disponible pour le moment</p>
        </div>
      <% } else { %>
        <div class="pub-links">
          <% event.links.forEach(function(l, i){ %>
            <a href="/go/<%= l.id %>" class="pub-btn pub-link-<%= i %>" target="_blank" rel="noopener">
              <span class="pub-btn-icon"><i class="bi bi-<%= iconFor(l.type) %>"></i></span>
              <span class="pub-btn-title"><%= l.title %></span>
              <i class="bi bi-arrow-right pub-btn-arrow"></i>
            </a>
          <% }); %>
        </div>
      <% } %>
    </div>

    <div class="pub-footer">
      Powered by <a href="/">BeyondCom</a>
    </div>
  </div>
</body>
</html>
