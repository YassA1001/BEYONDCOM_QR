<!DOCTYPE html>
<html lang="fr" class="h-100">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Connexion · BeyondCom</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%230f172a'/><text x='50' y='68' font-size='56' font-family='Arial' font-weight='bold' fill='%2338bdf8' text-anchor='middle'>B</text></svg>">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body class="auth-page">
  <div class="auth-bg" aria-hidden="true">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
  </div>

  <div class="auth-wrap">
    <div class="auth-card fade-in">
      <div class="auth-brand">
        <div class="brand-mark-lg"><i class="bi bi-qr-code"></i></div>
        <div>
          <div class="auth-brand-name">BeyondCom</div>
          <div class="auth-brand-sub">QR Event Platform</div>
        </div>
      </div>

      <h1 class="auth-title">Connexion</h1>
      <p class="auth-subtitle">Accédez à votre espace d'administration.</p>

      <% if (flash && flash.error) { %>
        <div class="alert alert-danger d-flex align-items-center fade-in-up">
          <i class="bi bi-exclamation-triangle me-2"></i><div><%= flash.error %></div>
        </div>
      <% } %>
      <% if (flash && flash.success) { %>
        <div class="alert alert-success d-flex align-items-center fade-in-up">
          <i class="bi bi-check-circle me-2"></i><div><%= flash.success %></div>
        </div>
      <% } %>

      <form action="/login" method="post" class="auth-form" novalidate>
        <div class="field">
          <label class="field-label">Email</label>
          <div class="field-with-icon">
            <i class="bi bi-envelope field-icon"></i>
            <input type="email" name="email" class="form-control <%= errors && errors.email ? 'is-invalid' : '' %>"
                   value="<%= old && old.email ? old.email : '' %>" placeholder="admin@beyondcom.local" required autofocus>
          </div>
          <% if (errors && errors.email) { %>
            <div class="field-error"><%= errors.email %></div>
          <% } %>
        </div>

        <div class="field">
          <label class="field-label">Mot de passe</label>
          <div class="field-with-icon">
            <i class="bi bi-lock field-icon"></i>
            <input type="password" name="password" id="password" class="form-control <%= errors && errors.password ? 'is-invalid' : '' %>"
                   placeholder="••••••••" required>
            <button type="button" class="toggle-pwd" id="togglePwd" aria-label="Afficher">
              <i class="bi bi-eye"></i>
            </button>
          </div>
          <% if (errors && errors.password) { %>
            <div class="field-error"><%= errors.password %></div>
          <% } %>
        </div>

        <button type="submit" class="btn btn-primary btn-pill w-100 auth-submit">
          <span class="btn-label"><i class="bi bi-box-arrow-in-right me-2"></i>Se connecter</span>
          <span class="btn-spinner spinner-border spinner-border-sm d-none"></span>
        </button>
      </form>

      <div class="auth-footer">
        Pas encore de compte ?
        <a href="/register">Créer un compte</a>
      </div>
    </div>

    <div class="auth-side-note">
      Plateforme événementielle · Pages dynamiques par QR code
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/app.js"></script>
</body>
</html>
