<div class="d-flex flex-wrap align-items-center justify-content-between gap-3 mb-4 fade-in">
  <div>
    <h2 class="page-h2">Événements</h2>
    <p class="text-muted mb-0">Gérez vos pages publiques et QR codes.</p>
  </div>
  <a href="/admin/events/create" class="btn btn-primary btn-pill">
    <i class="bi bi-plus-lg me-1"></i> Nouvel événement
  </a>
</div>

<div class="card-panel mb-4 fade-in">
  <div class="card-panel-body py-3">
    <form action="/admin/events" method="get" class="input-group input-group-merge">
      <span class="input-group-text bg-transparent"><i class="bi bi-search"></i></span>
      <input type="search" name="q" value="<%= q %>" class="form-control" placeholder="Rechercher un événement...">
      <button class="btn btn-primary" type="submit">Rechercher</button>
    </form>
  </div>
</div>

<% if (events.length === 0) { %>
  <div class="card-panel fade-in">
    <div class="card-panel-body">
      <div class="empty-state py-5">
        <i class="bi bi-calendar2-x"></i>
        <h4>Aucun événement</h4>
        <p>Commencez par créer votre premier événement pour générer un QR code.</p>
        <a href="/admin/events/create" class="btn btn-primary btn-pill mt-2">
          <i class="bi bi-plus-lg me-1"></i> Créer un événement
        </a>
      </div>
    </div>
  </div>
<% } else { %>
  <div class="row g-3">
    <% events.forEach(function(e, i){ %>
      <div class="col-12 col-md-6 col-xl-4 fade-in" style="--delay:<%= (i%6) * 60 %>ms">
        <div class="event-card lift h-100">
          <div class="event-card-banner" style="<% if (e.banner){ %>background-image:url('<%= e.banner %>');<% } else { %>background:linear-gradient(135deg, <%= e.primaryColor || '#0ea5e9' %>, #0f172a);<% } %>">
            <div class="event-card-status">
              <% if (e.isActive) { %>
                <span class="badge badge-active"><span class="dot"></span>Actif</span>
              <% } else { %>
                <span class="badge badge-inactive"><span class="dot"></span>Inactif</span>
              <% } %>
            </div>
            <% if (e.logo){ %>
              <div class="event-card-logo"><img src="<%= e.logo %>" alt=""></div>
            <% } %>
          </div>
          <div class="event-card-body">
            <h3 class="event-title"><%= e.name %></h3>
            <div class="event-meta">
              <% if (e.city){ %>
                <span><i class="bi bi-geo-alt"></i><%= e.city %></span>
              <% } %>
              <span><i class="bi bi-qr-code-scan"></i><%= e._count.scans %> scans</span>
              <span><i class="bi bi-hand-index-thumb"></i><%= e._count.clicks %> clics</span>
            </div>

            <div class="event-card-actions">
              <a href="/admin/events/<%= e.id %>" class="btn btn-soft btn-sm"><i class="bi bi-eye"></i> Voir</a>
              <a href="/admin/events/<%= e.id %>/links" class="btn btn-soft btn-sm"><i class="bi bi-link-45deg"></i> Liens</a>
              <a href="/admin/events/<%= e.id %>/qr" class="btn btn-soft btn-sm"><i class="bi bi-qr-code"></i> QR</a>
              <a href="/admin/events/<%= e.id %>/stats" class="btn btn-soft btn-sm"><i class="bi bi-bar-chart"></i> Stats</a>
            </div>

            <div class="event-card-footer">
              <form method="post" action="/admin/events/<%= e.id %>/toggle">
                <button class="toggle-switch" type="submit" data-on="<%= e.isActive %>">
                  <span></span>
                </button>
              </form>
              <div class="d-flex gap-1">
                <a href="/admin/events/<%= e.id %>/edit" class="btn btn-icon" title="Modifier"><i class="bi bi-pencil"></i></a>
                <button class="btn btn-icon text-danger" title="Supprimer"
                        data-confirm
                        data-form-action="/admin/events/<%= e.id %>/delete"
                        data-title="Supprimer l'événement"
                        data-message="Cette action supprimera l'événement « <%= e.name %> », ses liens et statistiques associées.">
                  <i class="bi bi-trash"></i>
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    <% }); %>
  </div>
<% } %>
